<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StoreJS — Edit Product</title>
    <style>
      body { background: #0d1117; color: #c9d1d9; font-family: "Segoe UI", system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; }
      h1 { color: #f0883e; border-bottom: 1px solid #30363d; padding-bottom: 8px; }
      a { color: #58a6ff; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .btn { display: inline-block; background: #238636; color: #fff; padding: 8px 16px; border-radius: 6px; text-decoration: none; margin: 2px 0; }
      .btn:hover { background: #2ea043; text-decoration: none; }
      .btn-danger { background: #da3633; }
      .btn-danger:hover { background: #f85149; }
      input, textarea { background: #161b22; color: #c9d1d9; border: 1px solid #30363d; padding: 10px; border-radius: 6px; width: 100%; box-sizing: border-box; font-size: 14px; }
      input:focus { border-color: #58a6ff; outline: none; }
      label { display: block; margin-bottom: 4px; color: #8b949e; font-size: 13px; }
      button { background: #238636; color: #fff; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-size: 14px; }
      button:hover { background: #2ea043; }
      .notice { background: #1f2937; border-left: 4px solid #58a6ff; padding: 10px 16px; border-radius: 4px; margin-bottom: 16px; }
      .error { background: #1f2937; border-left: 4px solid #da3633; padding: 10px 16px; border-radius: 4px; color: #f85149; }
      ul { list-style: none; padding: 0; }
      li { background: #161b22; margin: 8px 0; padding: 16px; border-radius: 8px; border: 1px solid #30363d; display: flex; justify-content: space-between; align-items: center; }
      li:hover { border-color: #58a6ff; }
      .empty { color: #8b949e; font-style: italic; padding: 40px 0; text-align: center; }
      .nav { margin-bottom: 24px; padding: 12px 0; border-bottom: 1px solid #30363d; }
      .nav a { margin-right: 16px; }
      form p { margin: 16px 0; }
    </style>
  </head>
  <body>
    <div class="nav">
      <a href="/products/<%= product.id %>" class="btn">← Back</a>
    </div>

    <h1>Edit Product</h1>

    <% if (errors && errors.length > 0) { %>
      <div class="error">
        <% errors.forEach(function(error) { %>
          <p><%= error %></p>
        <% }) %>
      </div>
    <% } %>

    <form action="/products/<%= product.id %>" method="post">
      <p>
        <label for="name">Name</label>
        <input id="name" name="name" type="text" value="<%= product.name %>" />
      </p>
      <p>
        <button type="submit">Update Product</button>
      </p>
    </form>
  </body>
</html>
